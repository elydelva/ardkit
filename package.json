{
  "name": "adrkit-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Decision-first, agent-native project management system for git repositories",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elydelva/adrkit.git"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": ["packages/*"],
  "catalog": {
    "typescript": "^5.7.0",
    "@biomejs/biome": "^1.9.4",
    "bun-types": "^1.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "ink": "^5.1.0",
    "react": "^18.3.0",
    "@types/react": "^18.3.0",
    "commander": "^13.0.0"
  },
  "scripts": {
    "build": "bun run --filter './packages/*' build",
    "build:bin": "bun build packages/adrkit/src/index.ts --compile --outfile dist/adrkit --target bun",
    "test": "bun test --coverage",
    "test:watch": "bun test --watch",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit --project tsconfig.base.json",
    "prepare": "husky",
    "clean": "bun run --filter './packages/*' clean"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "bun-types": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{ts,tsx}": "biome check --write"
  }
}
